<Window x:Class="RougelikeGame.Gui.DifficultySelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="難易度選択" Height="420" Width="480"
        Background="#1a1a2e" WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" Text="難易度を選択"
                   Foreground="#ffd700" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- 難易度リスト -->
        <Border Grid.Row="1" Background="#16213e" CornerRadius="5" Padding="5">
            <ListBox x:Name="DifficultyList" Background="Transparent" BorderThickness="0"
                     Foreground="White" FontSize="13" SelectionChanged="DifficultyList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="15" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Description}" Foreground="#a0a0a0" FontSize="11"
                                       TextWrapping="Wrap" Margin="24,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 詳細説明 -->
        <Border Grid.Row="2" Background="#0f3460" CornerRadius="5" Padding="10,5" Margin="0,8,0,0">
            <TextBlock x:Name="DetailText" Text="" Foreground="#e0e0e0" FontSize="12"
                       TextWrapping="Wrap" FontFamily="Consolas"/>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="ConfirmButton" Content="決定 [Enter]" Width="120" Height="35"
                    Click="ConfirmButton_Click" Background="#e94560" Foreground="White"
                    FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>
            <Button x:Name="CancelButton" Content="戻る [Esc]" Width="100" Height="35"
                    Click="CancelButton_Click" Background="#4a4a6a" Foreground="White" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>
