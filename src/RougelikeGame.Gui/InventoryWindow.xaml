<Window x:Class="RougelikeGame.Gui.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="所持品" 
        Height="400" Width="350"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="【所持品】" 
                   Foreground="#e94560" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" 
                 x:Name="ItemList"
                 Background="#16213e"
                 Foreground="White"
                 BorderBrush="#0f3460"
                 FontSize="14"
                 SelectionChanged="ItemList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DisplayName}" Foreground="White"/>
                        <TextBlock Text="{Binding EquippedText}" Foreground="#4ecca3" Margin="5,0,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="UseButton" 
                    Content="使用/装備 [Enter]" 
                    Width="120" 
                    Margin="5"
                    Click="UseButton_Click"
                    Background="#0f3460"
                    Foreground="White"
                    BorderBrush="#4ecca3"/>
            <Button Content="閉じる [Esc]" 
                    Width="100" 
                    Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460"
                    Foreground="White"
                    BorderBrush="#e94560"/>
        </StackPanel>
    </Grid>
</Window>
