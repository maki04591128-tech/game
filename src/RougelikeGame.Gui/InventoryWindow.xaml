<Window x:Class="RougelikeGame.Gui.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="所持品" 
        Height="580" Width="850"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="260"/>
        </Grid.ColumnDefinitions>

        <!-- 左側: グリッドインベントリ -->
        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="【グリッドインベントリ】" 
                           Foreground="#e94560" 
                           FontSize="18" 
                           FontWeight="Bold"/>
                <TextBlock x:Name="SpaceInfoText"
                           Foreground="#4ecca3" 
                           FontSize="14" 
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"/>
            </StackPanel>

            <Border Grid.Row="1" 
                    Background="#16213e" 
                    BorderBrush="#0f3460" 
                    BorderThickness="2" 
                    CornerRadius="4"
                    Padding="4">
                <Canvas x:Name="GridCanvas" 
                            Width="400" Height="240"
                            Background="#16213e"
                            MouseLeftButtonDown="GridCanvas_MouseDown"
                            MouseMove="GridCanvas_MouseMove"
                            MouseLeftButtonUp="GridCanvas_MouseUp"/>
            </Border>

            <Border Grid.Row="2" 
                    Background="#0f3460" 
                    CornerRadius="4" 
                    Padding="8" 
                    Margin="0,8,0,0"
                    MinHeight="60">
                <TextBlock x:Name="ItemDetailText"
                           Foreground="White" 
                           FontSize="13" 
                           TextWrapping="Wrap"
                           Text="アイテムをクリックして選択"/>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="UseButton" 
                        Content="使用/装備 [Enter]" 
                        Width="120" 
                        Margin="5"
                        Click="UseButton_Click"
                        IsEnabled="False"
                        Background="#0f3460"
                        Foreground="White"
                        BorderBrush="#4ecca3"/>
                <Button x:Name="SortButton"
                        Content="ソート [S]"
                        Width="90"
                        Margin="5"
                        Click="SortButton_Click"
                        Background="#0f3460"
                        Foreground="White"
                        BorderBrush="#ffd93d"/>
                <Button Content="閉じる [Esc]" 
                        Width="100" 
                        Margin="5"
                        Click="CloseButton_Click"
                        Background="#0f3460"
                        Foreground="White"
                        BorderBrush="#e94560"/>
            </StackPanel>
        </Grid>

        <!-- 右側: PoE風装備パネル + ステータス -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="【装備】" 
                       Foreground="#ffd93d" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>

            <Border Grid.Row="1" 
                    Background="#16213e" 
                    BorderBrush="#0f3460" 
                    BorderThickness="2" 
                    CornerRadius="4"
                    Padding="2">
                <Canvas x:Name="EquipmentCanvas" 
                        Width="244" Height="340"
                        Background="#16213e"/>
            </Border>

            <Border Grid.Row="2" 
                    Background="#0f3460" 
                    CornerRadius="4" 
                    Padding="8" 
                    Margin="0,8,0,0">
                <TextBlock x:Name="StatsText"
                           Foreground="#b0b0b0" 
                           FontSize="12" 
                           TextWrapping="Wrap"/>
            </Border>
        </Grid>
    </Grid>
</Window>
