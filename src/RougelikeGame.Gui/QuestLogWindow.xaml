<Window x:Class="RougelikeGame.Gui.QuestLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="クエストログ" 
        Height="500" Width="550"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="【クエストログ】" 
                       Foreground="#e94560" 
                       FontSize="18" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="GuildInfoText" Foreground="#ffd93d" FontSize="14" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- タブヘッダー -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <TextBlock Text="受注中クエスト" Foreground="#4ecca3" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock x:Name="CompletedCountText" Foreground="#808080" FontSize="12" VerticalAlignment="Center" Margin="15,0,0,0"/>
        </StackPanel>

        <!-- クエスト一覧 -->
        <ListBox Grid.Row="2"
                 x:Name="QuestList"
                 Background="#16213e"
                 Foreground="White"
                 BorderBrush="#0f3460"
                 FontSize="13"
                 SelectionChanged="QuestList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding StatusIcon}" FontSize="14" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding Name}" Foreground="#ffd93d" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TypeDisplay}" Foreground="#808080" Margin="8,0,0,0" FontSize="11"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ProgressText}" Foreground="#a0a0a0" FontSize="11" Margin="20,2,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 詳細表示 -->
        <Border Grid.Row="3" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock x:Name="QuestDetailText" Foreground="#a0a0a0" FontSize="12" TextWrapping="Wrap" Text="クエストを選択してください"/>
                <TextBlock x:Name="QuestRewardText" Foreground="#ffd700" FontSize="12" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
