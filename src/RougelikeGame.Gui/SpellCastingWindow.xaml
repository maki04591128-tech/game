<Window x:Class="RougelikeGame.Gui.SpellCastingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="魔法詠唱" 
        Height="600" Width="750"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" 
                   Text="【魔法詠唱】" 
                   Foreground="#e94560" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- タブコントロール -->
        <TabControl Grid.Row="1" Background="#1a1a2e" BorderBrush="#0f3460" Foreground="White"
                    x:Name="MainTabControl" SelectionChanged="MainTabControl_SelectionChanged">

            <!-- 詠唱作成タブ -->
            <TabItem Header="詠唱作成" Background="#0f3460" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- カテゴリ選択 + ルーン語リスト -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="カテゴリ: " Foreground="#4ecca3" FontSize="13" VerticalAlignment="Center"/>
                            <ComboBox x:Name="CategoryCombo" 
                                      Width="140"
                                      Background="#16213e" Foreground="White"
                                      SelectionChanged="CategoryCombo_SelectionChanged"/>
                        </StackPanel>

                        <ListBox Grid.Row="1"
                                 x:Name="RuneWordList"
                                 Background="#16213e"
                                 Foreground="White"
                                 BorderBrush="#0f3460"
                                 FontSize="13"
                                 SelectionChanged="RuneWordList_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Pronunciation}" Foreground="#00d9ff" Width="100"/>
                                        <TextBlock Text="{Binding Meaning}" Foreground="White" Width="80"/>
                                        <TextBlock Text="{Binding CategoryDisplay}" Foreground="#808080" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- 詠唱構成 -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="詠唱文" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>

                        <ListBox Grid.Row="1"
                                 x:Name="IncantationList"
                                 Background="#16213e"
                                 Foreground="White"
                                 BorderBrush="#0f3460"
                                 FontSize="13">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Pronunciation}" Foreground="#ffd93d" Width="100"/>
                                        <TextBlock Text="{Binding Meaning}" Foreground="White"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                            <Button Content="追加 [Enter]" Width="80" Margin="0,0,5,0"
                                    Click="AddButton_Click"
                                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
                            <Button Content="削除 [Del]" Width="80" Margin="0,0,5,0"
                                    Click="RemoveButton_Click"
                                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
                            <Button Content="記録 [S]" Width="80"
                                    Click="SaveSpellButton_Click"
                                    Background="#0f3460" Foreground="White" BorderBrush="#ffd93d" Padding="5,3"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- 記録済み呪文タブ -->
            <TabItem Header="記録済み呪文" Background="#0f3460" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <!-- 記録済み呪文リスト -->
                    <ListBox Grid.Column="0"
                             x:Name="SavedSpellList"
                             Background="#16213e"
                             Foreground="White"
                             BorderBrush="#0f3460"
                             FontSize="13"
                             SelectionChanged="SavedSpellList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding Name}" Foreground="#ffd93d" Width="140" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding MpCostText}" Foreground="#00d9ff" Width="70"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#a0a0a0" FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 呪文詳細 + アクション -->
                    <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="8" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock x:Name="SavedSpellNameText" Foreground="#ffd93d" FontSize="15" FontWeight="Bold" TextWrapping="Wrap" Text="呪文を選択"/>
                            <TextBlock x:Name="SavedSpellIncantText" Foreground="#ffd93d" FontSize="12" FontStyle="Italic" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock x:Name="SavedSpellDescText" Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="SavedSpellMpText" Foreground="#00d9ff" FontSize="12" Margin="0,4,0,0"/>
                            <TextBlock x:Name="SavedSpellWordsText" Foreground="#808080" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>

                            <StackPanel Orientation="Vertical" Margin="0,12,0,0">
                                <Button Content="この呪文で詠唱 [L]" Margin="0,0,0,5"
                                        Click="LoadAndCastButton_Click"
                                        Background="#16213e" Foreground="#4ecca3" BorderBrush="#4ecca3" Padding="8,4" FontWeight="Bold"/>
                                <Button Content="詠唱文に読込 [Enter]" Margin="0,0,0,5"
                                        Click="LoadSpellButton_Click"
                                        Background="#16213e" Foreground="#ffd93d" BorderBrush="#ffd93d" Padding="8,4"/>
                                <Button Content="削除 [Delete]" 
                                        Click="DeleteSpellButton_Click"
                                        Background="#16213e" Foreground="#e94560" BorderBrush="#e94560" Padding="8,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- プレビュー -->
        <Border Grid.Row="2" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock Text="■ 詠唱プレビュー" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PreviewMpCost" Foreground="#00d9ff" FontSize="12" Grid.Column="0"/>
                    <TextBlock x:Name="PreviewTurnCost" Foreground="#ffd93d" FontSize="12" Grid.Column="1"/>
                    <TextBlock x:Name="PreviewSuccessRate" Foreground="#4ecca3" FontSize="12" Grid.Column="2"/>
                </Grid>
                <TextBlock x:Name="PreviewDescription" Foreground="#a0a0a0" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"/>
                <TextBlock x:Name="PreviewIncantation" Foreground="#ffd93d" FontSize="12" FontStyle="Italic" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ステータスバー -->
        <Border Grid.Row="3" Margin="0,5,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="現在MP: " Foreground="White" FontSize="12"/>
                <TextBlock x:Name="CurrentMpText" Foreground="#00d9ff" FontSize="12" FontWeight="Bold" Margin="0,0,15,0"/>
                <TextBlock x:Name="ValidityText" Foreground="#808080" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="詠唱実行 [C]" Width="120" Margin="5"
                    Click="CastButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
