<Window x:Class="RougelikeGame.Gui.DialogueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="会話" 
        Height="350" Width="500"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 話者名 -->
        <Border Grid.Row="0" Background="#16213e" BorderBrush="#4ecca3" BorderThickness="0,0,0,2" Padding="10,5" Margin="0,0,0,8">
            <TextBlock x:Name="SpeakerName" 
                       Foreground="#4ecca3" 
                       FontSize="16" 
                       FontWeight="Bold"/>
        </Border>

        <!-- 会話テキスト -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="DialogueText" 
                           Foreground="White" 
                           FontSize="14" 
                           TextWrapping="Wrap"
                           LineHeight="22"/>
            </ScrollViewer>
        </Border>

        <!-- 選択肢 -->
        <ListBox Grid.Row="2"
                 x:Name="ChoiceList"
                 Background="#16213e"
                 Foreground="White"
                 BorderBrush="#0f3460"
                 FontSize="13"
                 Margin="0,8,0,0"
                 Visibility="Collapsed"
                 SelectionChanged="ChoiceList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Number}" Foreground="#ffd93d" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Text}" Foreground="White"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- フッター -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="ContinueButton" Content="続ける [Enter/Space]" Width="160" Margin="5"
                    Click="ContinueButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
