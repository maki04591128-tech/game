<Window x:Class="RougelikeGame.Gui.KeyBindingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="⌨ キーバインド設定"
        Height="600" Width="700"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="ActionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#c0c0d0"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="KeyButton" TargetType="Button">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#e0e0ff"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#404060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e94560"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        <Style x:Key="BottomButton" TargetType="Button">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#c0c0d0"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="25,8"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#404060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" Text="⌨ キーバインド設定" 
                   FontFamily="Yu Gothic UI" FontSize="20" FontWeight="Bold"
                   Foreground="#e94560" Margin="0,0,0,8"/>

        <!-- キーバインド一覧 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="BindingListPanel"/>
        </ScrollViewer>

        <!-- キャプチャ中メッセージ -->
        <Border x:Name="CaptureOverlay" Grid.Row="0" Grid.RowSpan="4"
                Background="#CC000000" Visibility="Collapsed" CornerRadius="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="新しいキーを押してください" 
                           Foreground="#e94560" FontFamily="Yu Gothic UI" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Escでキャンセル" 
                           Foreground="#808090" FontFamily="Yu Gothic UI" FontSize="14"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock x:Name="CaptureActionText" Text=""
                           Foreground="#c0c0d0" FontFamily="Yu Gothic UI" FontSize="16"
                           HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Content="保存" Style="{StaticResource BottomButton}" Click="SaveButton_Click"/>
            <Button Content="キャンセル" Style="{StaticResource BottomButton}" Click="CancelButton_Click"/>
            <Button Content="初期値に戻す" Style="{StaticResource BottomButton}" Click="ResetButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
