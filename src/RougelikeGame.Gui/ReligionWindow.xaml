<Window x:Class="RougelikeGame.Gui.ReligionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="宗教・信仰" 
        Height="500" Width="500"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" 
                   Text="【宗教・信仰】" 
                   Foreground="#e94560" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- 現在の信仰状態 -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="■ 現在の信仰" Foreground="#4ecca3" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock x:Name="ReligionNameText" Foreground="#ffd93d" FontSize="16" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <TextBlock x:Name="FaithRankText" Foreground="#c0a0ff" FontSize="13"/>
                    <TextBlock x:Name="FaithPointsText" Foreground="#a0a0a0" FontSize="13" Margin="15,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="ReligionTitleText" Foreground="#ffd700" FontSize="13" FontStyle="Italic" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- 恩恵一覧 / 宗教選択 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="ListTitle" Text="恩恵一覧" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox Grid.Row="1"
                     x:Name="BenefitList"
                     Background="#16213e"
                     Foreground="White"
                     BorderBrush="#0f3460"
                     FontSize="13">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusIcon}" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Name}" Foreground="#ffd93d"/>
                                <TextBlock Text="{Binding RequiredRank}" Foreground="#808080" Margin="8,0,0,0" FontSize="11"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Description}" Foreground="#a0a0a0" FontSize="11" Margin="20,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- 背教警告 -->
        <Border Grid.Row="3" x:Name="ApostasyWarning" Background="#3a1020" BorderBrush="#e94560" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0" Visibility="Collapsed">
            <TextBlock x:Name="ApostasyText" Foreground="#ff6b6b" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="PrayButton" Content="祈る [P]" Width="80" Margin="5"
                    Click="PrayButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button x:Name="LeaveButton" Content="棄教" Width="80" Margin="5"
                    Click="LeaveButton_Click" Visibility="Collapsed"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
