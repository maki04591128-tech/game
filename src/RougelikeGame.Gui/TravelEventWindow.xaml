<Window x:Class="RougelikeGame.Gui.TravelEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="旅路イベント" Height="320" Width="480"
        Background="#1a1a2e" WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- イベント名 -->
        <TextBlock x:Name="EventTitle" Text="旅路イベント"
                   Foreground="#ffd700" FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,8"/>

        <!-- イベント説明 -->
        <TextBlock x:Name="EventDescription" Grid.Row="1" Text=""
                   Foreground="#e0e0e0" FontSize="14" TextWrapping="Wrap"
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <!-- 結果表示 -->
        <Border Grid.Row="2" Background="#16213e" CornerRadius="5" Padding="10">
            <TextBlock x:Name="ResultText" Text=""
                       Foreground="#a0a0a0" FontSize="13" TextWrapping="Wrap"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Border>

        <!-- 選択肢ボタン -->
        <StackPanel x:Name="ChoicePanel" Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="ForceButton" Content="力で解決 [1]" Width="120" Height="32"
                    Click="ForceButton_Click" Background="#e94560" Foreground="White" FontSize="12"
                    Margin="0,0,8,0"/>
            <Button x:Name="NegotiateButton" Content="交渉する [2]" Width="120" Height="32"
                    Click="NegotiateButton_Click" Background="#2d6a4f" Foreground="White" FontSize="12"
                    Margin="0,0,8,0"/>
            <Button x:Name="EvadeButton" Content="回避する [3]" Width="120" Height="32"
                    Click="EvadeButton_Click" Background="#4a4a6a" Foreground="White" FontSize="12"/>
        </StackPanel>

        <!-- 閉じるボタン -->
        <Button x:Name="CloseBtn" Grid.Row="4" Content="閉じる [Esc]" Width="100" Height="30"
                Click="CloseButton_Click" Background="#4a4a6a" Foreground="White" FontSize="12"
                HorizontalAlignment="Center" Margin="0,10,0,0" Visibility="Collapsed"/>
    </Grid>
</Window>
