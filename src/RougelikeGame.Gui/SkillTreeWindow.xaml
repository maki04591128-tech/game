<Window x:Class="RougelikeGame.Gui.SkillTreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="スキルツリー" 
        Height="750" Width="1100"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="【スキルツリー】" 
                       Foreground="#e94560" 
                       FontSize="18" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="PointsText"
                       Foreground="#4ecca3" 
                       FontSize="14" 
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
        </StackPanel>

        <!-- ステータスボーナス合計 -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="6" Margin="0,0,0,6">
            <StackPanel>
                <TextBlock Text="■ 取得済みボーナス合計" Foreground="#4ecca3" FontSize="12" FontWeight="Bold" Margin="0,0,0,2"/>
                <TextBlock x:Name="TotalBonusText" Foreground="#c0c0c0" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 5タブ: 種族/職業/素性/武器/魔法 -->
        <TabControl Grid.Row="2" Background="#1a1a2e" BorderBrush="#0f3460" Foreground="White"
                    SelectionChanged="TabControl_SelectionChanged">
            <!-- 種族タブ -->
            <TabItem Header="種族" Background="#0f3460" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0d1b2a" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="RaceTreeCanvas" Width="1600" Height="280" Background="#0d1b2a" 
                                    MouseLeftButtonDown="TreeCanvas_MouseDown"/>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="8" Margin="6,0,0,0">
                        <StackPanel x:Name="RaceDetailPanel">
                            <TextBlock x:Name="RaceNodeNameText" Foreground="#ffd93d" FontSize="15" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="RaceNodeTypeText" Foreground="#808080" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock x:Name="RaceNodeDescText" Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="RaceNodePrereqText" Foreground="#c0a0ff" FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="RaceNodeBonusText" Foreground="#4ecca3" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 職業タブ -->
            <TabItem Header="職業" Background="#0f3460" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0d1b2a" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="ClassTreeCanvas" Width="1600" Height="500" Background="#0d1b2a"
                                    MouseLeftButtonDown="TreeCanvas_MouseDown"/>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="8" Margin="6,0,0,0">
                        <StackPanel x:Name="ClassDetailPanel">
                            <TextBlock x:Name="ClassNodeNameText" Foreground="#ffd93d" FontSize="15" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="ClassNodeTypeText" Foreground="#808080" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock x:Name="ClassNodeDescText" Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="ClassNodePrereqText" Foreground="#c0a0ff" FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="ClassNodeBonusText" Foreground="#4ecca3" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="ClassNodeDownsideText" Foreground="#e94560" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 素性タブ -->
            <TabItem Header="素性" Background="#0f3460" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0d1b2a" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="BackgroundTreeCanvas" Width="1600" Height="280" Background="#0d1b2a"
                                    MouseLeftButtonDown="TreeCanvas_MouseDown"/>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="8" Margin="6,0,0,0">
                        <StackPanel x:Name="BackgroundDetailPanel">
                            <TextBlock x:Name="BgNodeNameText" Foreground="#ffd93d" FontSize="15" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="BgNodeTypeText" Foreground="#808080" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock x:Name="BgNodeDescText" Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="BgNodePrereqText" Foreground="#c0a0ff" FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="BgNodeBonusText" Foreground="#4ecca3" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 武器タブ -->
            <TabItem Header="武器" Background="#0f3460" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0d1b2a" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="WeaponTreeCanvas" Width="1200" Height="400" Background="#0d1b2a"
                                    MouseLeftButtonDown="TreeCanvas_MouseDown"/>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="8" Margin="6,0,0,0">
                        <StackPanel x:Name="WeaponDetailPanel">
                            <TextBlock x:Name="WeaponNodeNameText" Foreground="#ffd93d" FontSize="15" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="WeaponNodeTypeText" Foreground="#808080" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock x:Name="WeaponNodeDescText" Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="WeaponNodePrereqText" Foreground="#c0a0ff" FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="WeaponNodeBonusText" Foreground="#4ecca3" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 魔法タブ -->
            <TabItem Header="魔法" Background="#0f3460" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0d1b2a" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Canvas x:Name="MagicTreeCanvas" Width="1200" Height="400" Background="#0d1b2a"
                                    MouseLeftButtonDown="TreeCanvas_MouseDown"/>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="8" Margin="6,0,0,0">
                        <StackPanel x:Name="MagicDetailPanel">
                            <TextBlock x:Name="MagicNodeNameText" Foreground="#ffd93d" FontSize="15" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="MagicNodeTypeText" Foreground="#808080" FontSize="11" Margin="0,3,0,0"/>
                            <TextBlock x:Name="MagicNodeDescText" Foreground="White" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="MagicNodePrereqText" Foreground="#c0a0ff" FontSize="10" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            <TextBlock x:Name="MagicNodeBonusText" Foreground="#4ecca3" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- キーストーン警告 -->
        <Border Grid.Row="3" x:Name="KeystoneWarning" Background="#3a1020" BorderBrush="#e94560" BorderThickness="1" CornerRadius="3" Padding="6" Margin="0,6,0,0" Visibility="Collapsed">
            <TextBlock x:Name="KeystoneWarningText" Foreground="#ff6b6b" FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- スキルスロット -->
        <Border Grid.Row="4" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="6" Margin="0,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" x:Name="SkillSlotPanel" Orientation="Horizontal"/>
                <TextBlock Grid.Column="1" x:Name="SlotInfoText" Foreground="#808080" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
            <Button x:Name="UnlockButton" Content="解放 [Enter]" Width="100" Margin="5"
                    Click="UnlockButton_Click" IsEnabled="False"
                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button x:Name="RespecButton" Content="リスペック [R]" Width="120" Margin="5"
                    Click="RespecButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#ffd93d" Padding="5,3"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
