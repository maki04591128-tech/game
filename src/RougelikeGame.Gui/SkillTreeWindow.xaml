<Window x:Class="RougelikeGame.Gui.SkillTreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="スキルツリー" 
        Height="650" Width="750"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="【スキルツリー】" 
                       Foreground="#e94560" 
                       FontSize="18" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="PointsText"
                       Foreground="#4ecca3" 
                       FontSize="14" 
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
        </StackPanel>

        <!-- ステータスボーナス合計 -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="■ 取得済みボーナス合計" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBlock x:Name="TotalBonusText" Foreground="#c0c0c0" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- タブ: スキルツリー + 習得済みスキル -->
        <TabControl Grid.Row="2" Background="#1a1a2e" BorderBrush="#0f3460" Foreground="White"
                    SelectionChanged="TabControl_SelectionChanged">
            <!-- スキルツリータブ -->
            <TabItem Header="ツリー" Background="#0f3460" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <ListBox Grid.Column="0"
                             x:Name="NodeList"
                             Background="#16213e"
                             Foreground="White"
                             BorderBrush="#0f3460"
                             FontSize="13"
                             SelectionChanged="NodeList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding TierLabel}" Width="16" Foreground="#606080" FontSize="9" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding StatusIcon}" Width="20"/>
                                    <TextBlock Text="{Binding TypeIcon}" Width="20" Foreground="#808080"/>
                                    <TextBlock Text="{Binding Name}" Foreground="{Binding NameColor}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CostText}" Foreground="#808080" Margin="8,0,0,0" FontSize="11"/>
                                    <TextBlock Text="{Binding LevelText}" Foreground="#606090" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- ノード詳細 -->
                    <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="10" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock x:Name="NodeNameText" Foreground="#ffd93d" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="NodeTypeText" Foreground="#808080" FontSize="12" Margin="0,3,0,0"/>
                            <TextBlock x:Name="NodeTierText" Foreground="#a0a0ff" FontSize="12" Margin="0,3,0,0"/>
                            <TextBlock x:Name="NodeDescText" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            <TextBlock x:Name="NodePrereqText" Foreground="#c0a0ff" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            <TextBlock x:Name="NodeBonusText" Foreground="#4ecca3" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            <TextBlock x:Name="NodeDownsideText" Foreground="#e94560" FontSize="12" TextWrapping="Wrap" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 習得済みスキルタブ -->
            <TabItem Header="習得済み / スロット" Background="#0f3460" Foreground="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <!-- 習得済みスキル一覧 -->
                    <Border Grid.Column="0" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" Padding="4">
                        <StackPanel>
                            <TextBlock Text="習得済みスキル（ドラッグでスロットに装備）" Foreground="#ffd93d" FontSize="12" Margin="0,0,0,4"/>
                            <ListBox x:Name="UnlockedSkillList"
                                     Background="#16213e"
                                     Foreground="White"
                                     BorderThickness="0"
                                     FontSize="13"
                                     AllowDrop="False"
                                     PreviewMouseLeftButtonDown="UnlockedSkillList_PreviewMouseDown"
                                     PreviewMouseMove="UnlockedSkillList_PreviewMouseMove">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="2">
                                            <TextBlock Text="{Binding TypeIcon}" Width="20" Foreground="#808080"/>
                                            <TextBlock Text="{Binding Name}" Foreground="#4ecca3" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Description}" Foreground="#808080" Margin="8,0,0,0" FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- スキルスロット -->
                    <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="10" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="スキルスロット" Foreground="#ffd93d" FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>
                            <StackPanel x:Name="SkillSlotPanel" AllowDrop="True"
                                        Drop="SkillSlotPanel_Drop" DragOver="SkillSlotPanel_DragOver"/>
                            <TextBlock x:Name="SlotInfoText" Foreground="#808080" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"
                                       Text="左の一覧からドラッグ＆ドロップでスロットに装備できます"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- キーストーン警告 -->
        <Border Grid.Row="3" x:Name="KeystoneWarning" Background="#3a1020" BorderBrush="#e94560" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0" Visibility="Collapsed">
            <TextBlock x:Name="KeystoneWarningText" Foreground="#ff6b6b" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="UnlockButton" Content="解放 [Enter]" Width="100" Margin="5"
                    Click="UnlockButton_Click" IsEnabled="False"
                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button x:Name="RespecButton" Content="リスペック [R]" Width="120" Margin="5"
                    Click="RespecButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#ffd93d" Padding="5,3"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
