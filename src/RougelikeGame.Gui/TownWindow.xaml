<Window x:Class="RougelikeGame.Gui.TownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="街メニュー" Height="520" Width="640"
        Background="#1a1a2e" WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 領地・街名 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="TownTitle" Text="王都" 
                       Foreground="#ffd700" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock x:Name="TownDescription" Text="" 
                       Foreground="#a0a0a0" FontSize="13" HorizontalAlignment="Center" Margin="0,3,0,0"/>
            <TextBlock x:Name="GoldDisplay" Text="所持金: 0G | 銀行残高: 0G"
                       Foreground="#ffd700" FontSize="13" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 施設一覧ラベル -->
        <TextBlock Grid.Row="1" Text="利用可能な施設" 
                   Foreground="#e94560" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>

        <!-- 施設リスト -->
        <Border Grid.Row="2" Background="#16213e" CornerRadius="5" Padding="5">
            <ListBox x:Name="FacilityList" Background="Transparent" BorderThickness="0"
                     Foreground="White" FontSize="13" SelectionChanged="FacilityList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5,3">
                            <TextBlock Text="{Binding Icon}" Width="25" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}" Foreground="#a0a0a0" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 銀行操作パネル（銀行選択時のみ表示） -->
        <Border x:Name="BankPanel" Grid.Row="3" Background="#0f3460" CornerRadius="5" 
                Padding="10,8" Margin="0,8,0,0" Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="銀行操作" Foreground="#ffd700" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="金額:" Foreground="White" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="BankAmountBox" Width="100" FontSize="13" Text="100"
                             Background="#1a1a2e" Foreground="White" BorderBrush="#4a4a6a" Padding="3"/>
                    <Button x:Name="DepositButton" Content="預入" Width="60" Margin="8,0,0,0"
                            Click="DepositButton_Click" Background="#2d6a4f" Foreground="White" FontSize="13"/>
                    <Button x:Name="WithdrawButton" Content="引出" Width="60" Margin="8,0,0,0"
                            Click="WithdrawButton_Click" Background="#d4a373" Foreground="Black" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ボタンエリア -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="UseButton" Content="利用する [Enter]" Width="130" Height="32"
                    Click="UseButton_Click" Background="#e94560" Foreground="White" FontSize="13" FontWeight="Bold"
                    Margin="0,0,10,0"/>
            <Button x:Name="DungeonButton" Content="ダンジョンへ [D]" Width="140" Height="32"
                    Click="DungeonButton_Click" Background="#7b2d8e" Foreground="White" FontSize="13" FontWeight="Bold"
                    Margin="0,0,10,0"/>
            <Button Content="閉じる [Esc]" Width="100" Height="32"
                    Click="CloseButton_Click" Background="#4a4a6a" Foreground="White" FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>
