<Window x:Class="RougelikeGame.Gui.CraftingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="合成工房" 
        Height="500" Width="550"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" 
                   Text="【合成工房】" 
                   Foreground="#e94560" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- タブ切替 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <Button x:Name="CraftTab" Content="合成" Width="80" Margin="0,0,5,0"
                    Click="CraftTab_Click"
                    Background="#4ecca3" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button x:Name="EnhanceTab" Content="強化" Width="80" Margin="0,0,5,0"
                    Click="EnhanceTab_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#0f3460" Padding="5,3"/>
            <Button x:Name="EnchantTab" Content="付与" Width="80"
                    Click="EnchantTab_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#0f3460" Padding="5,3"/>
        </StackPanel>

        <!-- 一覧 -->
        <ListBox Grid.Row="2"
                 x:Name="ItemList"
                 Background="#16213e"
                 Foreground="White"
                 BorderBrush="#0f3460"
                 FontSize="13"
                 SelectionChanged="ItemList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Foreground="#ffd93d" FontWeight="Bold"/>
                            <TextBlock Text="{Binding CostDisplay}" Foreground="#ffd700" Margin="10,0,0,0" FontSize="11"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Description}" Foreground="#a0a0a0" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 詳細 -->
        <Border Grid.Row="3" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock x:Name="DetailText" Foreground="#a0a0a0" FontSize="12" TextWrapping="Wrap" Text="項目を選択してください"/>
                <TextBlock x:Name="MaterialsText" Foreground="#c0a0ff" FontSize="12" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="ActionButton" Content="合成 [Enter]" Width="120" Margin="5"
                    Click="ActionButton_Click" IsEnabled="False"
                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
