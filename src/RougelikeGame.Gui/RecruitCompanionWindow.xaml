<Window x:Class="RougelikeGame.Gui.RecruitCompanionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="仲間募集" Height="500" Width="550"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="MS Gothic"
        Foreground="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" Text="🛡 仲間募集掲示板" FontSize="18" FontWeight="Bold"
                   Foreground="#e94560" Margin="0,0,0,10"/>

        <!-- 候補一覧 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
            <StackPanel x:Name="CandidatePanel" />
        </ScrollViewer>

        <!-- 閉じるボタン -->
        <Button Grid.Row="2" Content="閉じる" Width="100" Height="30"
                Background="#0f3460" Foreground="White" BorderBrush="#533483"
                Click="CloseButton_Click" HorizontalAlignment="Right"/>
    </Grid>
</Window>
