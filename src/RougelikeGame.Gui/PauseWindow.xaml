<Window x:Class="RougelikeGame.Gui.PauseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ポーズ"
        Height="420" Width="360"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <Style x:Key="PauseButton" TargetType="Button">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#c0c0d0"/>
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="250"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="BorderBrush" Value="#404060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1f3460"/>
                    <Setter Property="Foreground" Value="#e94560"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#1a1a2e" BorderBrush="#e94560" BorderThickness="2" CornerRadius="10">
        <Grid Margin="20,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- タイトル -->
            <TextBlock Grid.Row="0" Text="⏸ ポーズ" 
                       FontFamily="Yu Gothic UI" FontSize="24" FontWeight="Bold"
                       Foreground="#e94560" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- メニュー -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button Content="▶ ゲームに戻る" Style="{StaticResource PauseButton}" Click="ResumeButton_Click"/>
                <Button Content="💾 セーブ" Style="{StaticResource PauseButton}" Click="SaveButton_Click"/>
                <Button Content="📂 ロード" Style="{StaticResource PauseButton}" Click="LoadButton_Click"/>
                <Button Content="⚙ 設定" Style="{StaticResource PauseButton}" Click="SettingsButton_Click"/>
                <Button Content="⌨ キーバインド" Style="{StaticResource PauseButton}" Click="KeyBindButton_Click"/>
                <Button Content="🚪 タイトルに戻る" Style="{StaticResource PauseButton}" Click="TitleButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
