<Window x:Class="RougelikeGame.Gui.GameOverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="ゲームオーバー"
        Height="480" Width="520"
        Background="#0d0d1a"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Border BorderBrush="#600000" BorderThickness="2" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトル -->
            <TextBlock x:Name="TitleText"
                       Grid.Row="0"
                       Text="— GAME OVER —"
                       Foreground="#CC2222"
                       FontFamily="Yu Gothic UI"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,32,0,8"
                       Opacity="0"/>

            <!-- 結果テキスト -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,8">
                <TextBlock x:Name="ResultText"
                           Foreground="#D0B0B0"
                           FontFamily="Yu Gothic UI"
                           FontSize="15"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           LineHeight="26"
                           VerticalAlignment="Center"
                           Opacity="0"/>
            </ScrollViewer>

            <!-- ボタン群 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,16,0,32"
                        Opacity="0" x:Name="ButtonPanel">
                <Button x:Name="ReturnTitleButton"
                        Content="タイトルに戻る"
                        Click="ReturnTitle_Click"
                        Width="180" Height="42" Margin="10,0"
                        FontFamily="Yu Gothic UI" FontSize="15"
                        Background="#2a1010" Foreground="#FFAAAA"
                        BorderBrush="#993333" BorderThickness="1"
                        Cursor="Hand"/>
                <Button x:Name="QuitButton"
                        Content="ゲームを終了"
                        Click="Quit_Click"
                        Width="180" Height="42" Margin="10,0"
                        FontFamily="Yu Gothic UI" FontSize="15"
                        Background="#1a1a2e" Foreground="#9090C0"
                        BorderBrush="#404060" BorderThickness="1"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
