<Window x:Class="RougelikeGame.Gui.DeathLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="死亡録" 
        Height="550" Width="600"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="【死亡録】" 
                       Foreground="#e94560" 
                       FontSize="18" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="TotalDeathsText"
                       Foreground="#808080" 
                       FontSize="14" 
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
        </StackPanel>

        <!-- 統計情報 -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="■ 統計" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBlock x:Name="HighestLevelText" Foreground="#ffd93d" FontSize="12"/>
                    <TextBlock x:Name="DeepestFloorText" Foreground="#c0a0ff" FontSize="12" Margin="0,2,0,0"/>
                    <TextBlock x:Name="MostCommonCauseText" Foreground="#e94560" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="■ 死因内訳" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBlock x:Name="CauseBreakdownText" Foreground="#c0c0c0" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 死亡ログ一覧 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="死亡記録" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox Grid.Row="1"
                     x:Name="LogList"
                     Background="#16213e"
                     Foreground="White"
                     BorderBrush="#0f3460"
                     FontSize="12">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#0f3460" CornerRadius="3" Padding="6" Margin="0,1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding RunText}" Foreground="#808080" Width="60"/>
                                    <TextBlock Text="{Binding CharacterText}" Foreground="#ffd93d" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding LevelText}" Foreground="#4ecca3" Margin="8,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding CauseText}" Foreground="#e94560"/>
                                    <TextBlock Text="{Binding LocationText}" Foreground="#c0a0ff" Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding TurnText}" Foreground="#808080" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ボタン -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
