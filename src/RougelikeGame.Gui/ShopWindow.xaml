<Window x:Class="RougelikeGame.Gui.ShopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ショップ" 
        Height="620" Width="900"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル + 所持金 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock x:Name="ShopTitle"
                       Text="【ショップ】" 
                       Foreground="#e94560" 
                       FontSize="18" 
                       FontWeight="Bold"/>
            <TextBlock Text="　💰 所持金: " Foreground="White" FontSize="14" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <TextBlock x:Name="GoldText" Foreground="#ffd700" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 双方リスト: ショップ商品 + プレイヤーインベントリ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左: ショップ商品リスト -->
            <Border Grid.Column="0" Background="#16213e" BorderBrush="#0f3460" BorderThickness="2" CornerRadius="4" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="ShopGridLabel" Text="ショップ商品" Foreground="#4ecca3" FontSize="14" FontWeight="Bold" Margin="2,0,0,6"/>
                    <ListBox Grid.Row="1" x:Name="ShopListBox"
                             Background="#16213e" BorderThickness="0" Foreground="White" FontSize="13"
                             SelectionChanged="ShopListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PriceText}" Foreground="#ffd700" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="{Binding StockText}" Foreground="#a0a0a0" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 中央: 購入/売却ボタン -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="BuyButton" Content="購入 →" Width="70" Margin="0,0,0,8" Click="BuyButton_Click"
                        Background="#0f3460" Foreground="#4ecca3" BorderBrush="#4ecca3" Padding="5,6" FontWeight="Bold" IsEnabled="False"/>
                <Button x:Name="SellButton" Content="← 売却" Width="70" Margin="0,0,0,8" Click="SellButton_Click"
                        Background="#0f3460" Foreground="#e94560" BorderBrush="#e94560" Padding="5,6" FontWeight="Bold" IsEnabled="False"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Content="-" Width="24" Height="24" Click="QuantityDown_Click" Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" FontWeight="Bold"/>
                    <TextBlock x:Name="QuantityText" Text="1" Foreground="#ffd93d" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,6,0" MinWidth="20" TextAlignment="Center"/>
                    <Button Content="+" Width="24" Height="24" Click="QuantityUp_Click" Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="数量" Foreground="#808080" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- 右: プレイヤーインベントリリスト -->
            <Border Grid.Column="2" Background="#16213e" BorderBrush="#0f3460" BorderThickness="2" CornerRadius="4" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="PlayerGridLabel" Text="所持品" Foreground="#4ecca3" FontSize="14" FontWeight="Bold" Margin="2,0,0,6"/>
                    <ListBox Grid.Row="1" x:Name="PlayerListBox"
                             Background="#16213e" BorderThickness="0" Foreground="White" FontSize="13"
                             SelectionChanged="PlayerListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{Binding NameColor}" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PriceText}" Foreground="#ffd700" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- 選択アイテム情報 -->
        <Border Grid.Row="2" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0" MinHeight="40">
            <TextBlock x:Name="ItemInfoText" Foreground="#a0a0a0" FontSize="12" TextWrapping="Wrap" Text="ショップ商品を選択して「購入」、所持品を選択して「売却」"/>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
