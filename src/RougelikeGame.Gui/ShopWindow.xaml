<Window x:Class="RougelikeGame.Gui.ShopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ショップ" 
        Height="700" Width="1050"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル + 所持金 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock x:Name="ShopTitle"
                       Text="【ショップ】" 
                       Foreground="#e94560" 
                       FontSize="18" 
                       FontWeight="Bold"/>
            <TextBlock Text="　💰 所持金: " Foreground="White" FontSize="14" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <TextBlock x:Name="GoldText" Foreground="#ffd700" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 双方グリッド: ショップ商品グリッド + プレイヤーインベントリグリッド -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左: ショップ商品グリッド（PoE風） -->
            <Border Grid.Column="0" Background="#16213e" BorderBrush="#0f3460" BorderThickness="2" CornerRadius="4" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="ShopGridLabel" Text="ショップ商品" Foreground="#4ecca3" FontSize="14" FontWeight="Bold" Margin="2,0,0,6"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Canvas x:Name="ShopGridCanvas" 
                                Width="420" Height="360"
                                Background="#16213e"
                                MouseLeftButtonDown="ShopGridCanvas_MouseDown"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 中央: 購入/売却ボタン -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="BuyButton" Content="購入 →" Width="70" Margin="0,0,0,8" Click="BuyButton_Click"
                        Background="#0f3460" Foreground="#4ecca3" BorderBrush="#4ecca3" Padding="5,6" FontWeight="Bold" IsEnabled="False"/>
                <Button x:Name="SellButton" Content="← 売却" Width="70" Margin="0,0,0,8" Click="SellButton_Click"
                        Background="#0f3460" Foreground="#e94560" BorderBrush="#e94560" Padding="5,6" FontWeight="Bold" IsEnabled="False"/>
            </StackPanel>

            <!-- 右: プレイヤーインベントリグリッド（PoE風） -->
            <Border Grid.Column="2" Background="#16213e" BorderBrush="#0f3460" BorderThickness="2" CornerRadius="4" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Name="PlayerGridLabel" Text="所持品" Foreground="#4ecca3" FontSize="14" FontWeight="Bold" Margin="2,0,0,6"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Canvas x:Name="PlayerGridCanvas" 
                                Width="420" Height="360"
                                Background="#16213e"
                                MouseLeftButtonDown="PlayerGridCanvas_MouseDown"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 選択アイテム情報 -->
        <Border Grid.Row="2" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0" MinHeight="40">
            <TextBlock x:Name="ItemInfoText" Foreground="#a0a0a0" FontSize="12" TextWrapping="Wrap" Text="ショップ商品をクリックして「購入」、所持品をクリックして「売却」"/>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
