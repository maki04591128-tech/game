<Window x:Class="RougelikeGame.Gui.ShopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ショップ" 
        Height="500" Width="550"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" 
                   x:Name="ShopTitle"
                   Text="【ショップ】" 
                   Foreground="#e94560" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- 所持金 -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💰 所持金: " Foreground="White" FontSize="14"/>
                <TextBlock x:Name="GoldText" Foreground="#ffd700" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <!-- タブ切替 + 商品一覧 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                <Button x:Name="BuyTab" Content="購入" Width="80" Margin="0,0,5,0"
                        Click="BuyTab_Click"
                        Background="#4ecca3" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
                <Button x:Name="SellTab" Content="売却" Width="80"
                        Click="SellTab_Click"
                        Background="#0f3460" Foreground="White" BorderBrush="#0f3460" Padding="5,3"/>
            </StackPanel>

            <ListBox Grid.Row="1"
                     x:Name="ItemList"
                     Background="#16213e"
                     Foreground="White"
                     BorderBrush="#0f3460"
                     FontSize="13"
                     SelectionChanged="ItemList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="480">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" Foreground="White" Grid.Column="0"/>
                            <TextBlock Text="{Binding PriceDisplay}" Foreground="#ffd700" Grid.Column="1" Margin="10,0"/>
                            <TextBlock Text="{Binding StockDisplay}" Foreground="#808080" Grid.Column="2"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- 選択アイテム情報 -->
        <Border Grid.Row="3" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0">
            <TextBlock x:Name="ItemInfoText" Foreground="#a0a0a0" FontSize="12" TextWrapping="Wrap" Text="アイテムを選択してください"/>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="ActionButton" Content="購入 [Enter]" Width="120" Margin="5"
                    Click="ActionButton_Click" IsEnabled="False"
                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
