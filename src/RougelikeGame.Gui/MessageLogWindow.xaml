<Window x:Class="RougelikeGame.Gui.MessageLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="メッセージログ" 
        Height="500" Width="600"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" 
                   Text="【メッセージログ】" 
                   Foreground="#e94560" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- フィルタバー -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="フィルタ: " Foreground="#4ecca3" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Button x:Name="BtnAll" Content="全て" Click="Filter_Click" Tag="all" 
                        Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="8,3" Margin="2,0"/>
                <Button x:Name="BtnCombat" Content="戦闘" Click="Filter_Click" Tag="combat" 
                        Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="8,3" Margin="2,0"/>
                <Button x:Name="BtnItem" Content="アイテム" Click="Filter_Click" Tag="item" 
                        Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="8,3" Margin="2,0"/>
                <Button x:Name="BtnSystem" Content="システム" Click="Filter_Click" Tag="system" 
                        Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="8,3" Margin="2,0"/>
                <Button x:Name="BtnExplore" Content="探索" Click="Filter_Click" Tag="explore" 
                        Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="8,3" Margin="2,0"/>
            </StackPanel>
        </Border>

        <!-- ログ一覧 -->
        <Border Grid.Row="2" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8">
            <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogText" 
                           Foreground="#a0a0a0" 
                           FontFamily="Consolas" 
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- フッター -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <TextBlock Text="[Esc] 閉じる  [↑/↓] スクロール" 
                       Foreground="#808080" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
