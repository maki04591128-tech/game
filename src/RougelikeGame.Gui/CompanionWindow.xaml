<Window x:Class="RougelikeGame.Gui.CompanionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="仲間" 
        Height="550" Width="600"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="【仲間】" 
                       Foreground="#e94560" 
                       FontSize="18" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="PartyCountText"
                       Foreground="#4ecca3" 
                       FontSize="14" 
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
        </StackPanel>

        <!-- パーティ全体ステータス -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="■ パーティ状態" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,3"/>
                <TextBlock x:Name="PartyOverviewText" Foreground="#c0c0c0" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 仲間一覧と詳細 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                     x:Name="CompanionList"
                     Background="#16213e"
                     Foreground="White"
                     BorderBrush="#0f3460"
                     FontSize="13"
                     SelectionChanged="CompanionList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusIcon}" Width="20"/>
                                <TextBlock Text="{Binding Name}" Foreground="{Binding NameColor}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TypeText}" Foreground="#808080" Margin="8,0,0,0" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="20,2,0,0">
                                <TextBlock Text="{Binding HpText}" Foreground="#e94560" FontSize="11"/>
                                <TextBlock Text="{Binding AIModeText}" Foreground="#a0a0ff" FontSize="11" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 仲間詳細 -->
            <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="10" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="CompNameText" Foreground="#ffd93d" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="CompTypeText" Foreground="#808080" FontSize="12" Margin="0,3,0,0"/>
                    <TextBlock x:Name="CompLevelText" Foreground="#4ecca3" FontSize="13" Margin="0,5,0,0"/>
                    <TextBlock x:Name="CompHpText" Foreground="#e94560" FontSize="13" Margin="0,3,0,0"/>
                    <TextBlock x:Name="CompStatsText" Foreground="#c0c0c0" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="CompLoyaltyText" Foreground="#ffd93d" FontSize="12" Margin="0,5,0,0"/>

                    <!-- AIモード切替 -->
                    <TextBlock Text="AIモード:" Foreground="#a0a0ff" FontSize="12" Margin="0,10,0,3"/>
                    <ComboBox x:Name="AIModeCombo" Width="150" HorizontalAlignment="Left"
                              SelectionChanged="AIModeCombo_SelectionChanged"
                              Background="#16213e" Foreground="White" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 忠誠度警告 -->
        <Border Grid.Row="3" x:Name="LoyaltyWarning" Background="#3a1020" BorderBrush="#e94560" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0" Visibility="Collapsed">
            <TextBlock x:Name="LoyaltyWarningText" Foreground="#ff6b6b" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="DismissButton" Content="解雇 [D]" Width="100" Margin="5"
                    Click="DismissButton_Click" IsEnabled="False"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
