<Window x:Class="RougelikeGame.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RougelikeGame.Gui"
        mc:Ignorable="d"
        Title="ローグライクゲーム" 
        Height="720" Width="1024"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp"
        Loaded="Window_Loaded"
        Focusable="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- メインエリア: 左サイドバー + マップ + 右サイドバー -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- 左サイドバー（上: 場所/時刻、下: ステータス） -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 左上: 場所・時刻情報 -->
                <Border Grid.Row="0" Background="#16213e" Margin="2" Padding="6,4" CornerRadius="3">
                    <StackPanel>
                        <TextBlock x:Name="TerritoryText" Text="王都領" Foreground="#ffd93d" FontSize="13" FontWeight="Bold"/>
                        <TextBlock x:Name="SurfaceStatusText" Text="【地上】" Foreground="#4ecca3" FontSize="12" FontWeight="Bold" Margin="0,2,0,0"/>
                        <TextBlock x:Name="FloorText" Text="第1層" Foreground="#e94560" FontSize="14" FontWeight="Bold" Margin="0,2,0,0"/>
                        <Separator Background="#0f3460" Margin="0,4"/>
                        <TextBlock x:Name="DateText" Text="冒険歴1024年 緑風の月 15日 08:00" Foreground="#c0a0ff" FontSize="11" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock x:Name="TimePeriodText" Text="朝" Foreground="#ffd93d" FontSize="12" FontStyle="Italic"/>
                            <TextBlock Text=" | " Foreground="Gray" FontSize="12"/>
                            <TextBlock x:Name="SeasonText" Text="春" Foreground="#90EE90" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="WeatherText" Text="☀ 晴" Foreground="#87CEEB" FontSize="12" FontWeight="Bold" Margin="0,2,0,0"/>
                        <TextBlock x:Name="TurnLimitText" Text="残り365日" Foreground="#ff6b6b" FontSize="12" FontWeight="Bold" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 左下: HP/MP/SP等ステータス -->
                <Border Grid.Row="1" Background="#16213e" Margin="2" Padding="6,4" CornerRadius="3" VerticalAlignment="Bottom">
                    <StackPanel>
                        <TextBlock Text="── ステータス ──" Foreground="#808080" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Lv:" Foreground="White" FontSize="12"/>
                            <TextBlock x:Name="LevelText" Text="1" Foreground="#ffa500" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="HP: " Foreground="White" FontSize="12"/>
                            <TextBlock x:Name="HpText" Text="100/100" Foreground="#4ecca3" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="MP: " Foreground="White" FontSize="12"/>
                            <TextBlock x:Name="MpText" Text="50/50" Foreground="#00d9ff" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="SP: " Foreground="White" FontSize="12"/>
                            <TextBlock x:Name="SpText" Text="100/100" Foreground="#ffd93d" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                        <Separator Background="#0f3460" Margin="0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="満腹: " Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="HungerText" Text="100" Foreground="#ff6b6b" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="渇き: " Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="ThirstText" Text="潤沢" Foreground="#00BFFF" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="正気: " Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="SanityText" Text="100" Foreground="#c0a0ff" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="疲労: " Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="FatigueText" Text="元気" Foreground="#90EE90" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="衛生: " Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="HygieneText" Text="清潔" Foreground="#87CEEB" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="DiseaseText" Text="" Foreground="#FF4500" FontSize="11" FontWeight="Bold" Margin="0,1,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 中央: ゲームマップ -->
            <Border Grid.Column="1" Background="#0f0f23" Margin="2">
                <Grid>
                    <Canvas x:Name="GameCanvas" ClipToBounds="True"/>
                    <!-- ミニマップ（右上オーバーレイ） -->
                    <Border x:Name="MinimapBorder"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,5,5,0"
                            Background="#80000000"
                            BorderBrush="#404060"
                            BorderThickness="1"
                            CornerRadius="3"
                            Visibility="Visible">
                        <Canvas x:Name="MinimapCanvas" 
                                Width="160" Height="100"
                                ClipToBounds="True"/>
                    </Border>
                    <!-- Ver.β 視覚エフェクト用オーバーレイ -->
                    <!-- 正気度演出オーバーレイ（β.18） -->
                    <Border x:Name="SanityOverlay"
                            IsHitTestVisible="False"
                            Opacity="0"
                            Background="#00FF0000"/>
                    <!-- 被弾フラッシュオーバーレイ（β.11） -->
                    <Border x:Name="FlashOverlay"
                            IsHitTestVisible="False"
                            Opacity="0"
                            Background="#CCFF0000"/>
                    <!-- フローティングダメージ・状態異常テキスト用Canvas（β.9/β.12） -->
                    <Canvas x:Name="EffectCanvas"
                            IsHitTestVisible="False"
                            ClipToBounds="True"/>
                    <!-- フロア/死に戻り暗転オーバーレイ（β.13/β.20） -->
                    <Border x:Name="FadeOverlay"
                            IsHitTestVisible="False"
                            Opacity="0"
                            Background="Black"/>
                </Grid>
            </Border>

            <!-- 右サイドバー（上: ゴールド/経験値等、下: ログ） -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 右上: ゴールド・経験値・重量等 -->
                <Border Grid.Row="0" Background="#16213e" Margin="2" Padding="6,4" CornerRadius="3">
                    <StackPanel>
                        <TextBlock Text="── 所持情報 ──" Foreground="#808080" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰 " Foreground="#ffd700" FontSize="13"/>
                            <TextBlock x:Name="GoldText" Text="0G" Foreground="#ffd700" FontSize="13" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="EXP: " Foreground="White" FontSize="12"/>
                            <TextBlock x:Name="ExpText" Text="0/100" Foreground="#ffa500" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="⚖ " Foreground="#a0c4ff" FontSize="12"/>
                            <TextBlock x:Name="WeightText" Text="0/100kg" Foreground="#a0c4ff" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                        <Separator Background="#0f3460" Margin="0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="善悪: " Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="KarmaText" Text="中立" Foreground="#C0C0C0" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="仲間: " Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="CompanionCountText" Text="0" Foreground="#FFD700" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                            <TextBlock Text="構え: " Foreground="White" FontSize="11"/>
                            <TextBlock x:Name="StanceText" Text="均衡" Foreground="#87CEEB" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 右下: メッセージログ -->
                <Border Grid.Row="1" Background="#16213e" Margin="2" Padding="6,4" CornerRadius="3">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="── ログ ──" Foreground="#808080" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                        <ScrollViewer Grid.Row="1" x:Name="MessageScroller" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="MessageLog" 
                                       Foreground="#a0a0a0" 
                                       FontFamily="Consolas" 
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- スキルスロットアイコン（PoE風） -->
        <Border Grid.Row="1" Background="#0d1b2a" Margin="2,0" Padding="4,3" CornerRadius="3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="技:" Foreground="#808080" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <StackPanel x:Name="SkillSlotIconPanel" Orientation="Horizontal"/>
                <TextBlock x:Name="SkillSlotText" Text="" Foreground="#a0a0a0" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- 操作説明 -->
        <Border Grid.Row="2" Background="#0f3460" Padding="10,4">
            <TextBlock x:Name="KeyHelpText"
                       Text="[WASD/矢印]移動 [I]持物 [C]状態 [L]ログ [G]拾う [&gt;]降 [&lt;]昇 [Tab]探索 [M]地図 [J]世界 [K]依頼 [V]魔法 [E]技能 [O]信仰 [P]祈り [1-6]スキル [Y]図鑑 [U]仲間 [Z]死亡録 [T]入場 [F5]保存 [F9]読込 [Q]終了"
                       Foreground="#e0e0e0" 
                       FontSize="11" 
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
