<Window x:Class="RougelikeGame.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RougelikeGame.Gui"
        mc:Ignorable="d"
        Title="ローグライクゲーム" 
        Height="720" Width="1024"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Focusable="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ステータスバー -->
        <Border Grid.Row="0" Background="#16213e" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左: 領地 + 階層 + 日時 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="TerritoryText" Text="王都領" Foreground="#ffd93d" FontSize="14" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock x:Name="SurfaceStatusText" Text="【地上】" Foreground="#4ecca3" FontSize="14" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock x:Name="FloorText" Text="第1層" Foreground="#e94560" FontSize="16" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock x:Name="DateText" Text="冒険歴1024年 緑風の月 15日 08:00" Foreground="#c0a0ff" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TimePeriodText" Text="朝" Foreground="#ffd93d" FontSize="14" FontStyle="Italic" Margin="0,0,15,0"/>
                    <TextBlock x:Name="TurnLimitText" Text="残り365日" Foreground="#ff6b6b" FontSize="14" FontWeight="Bold"/>
                </StackPanel>

                <!-- 右: ステータス -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Lv:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="LevelText" Text="1" Foreground="#ffa500" FontSize="14" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="EXP:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="ExpText" Text="0/100" Foreground="#ffa500" FontSize="14" Margin="0,0,15,0"/>
                    <TextBlock Text="HP:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="HpText" Text="100/100" Foreground="#4ecca3" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="MP:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="MpText" Text="50/50" Foreground="#00d9ff" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="SP:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="SpText" Text="100/100" Foreground="#ffd93d" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="満腹:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="HungerText" Text="100" Foreground="#ff6b6b" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="正気:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="SanityText" Text="100" Foreground="#c0a0ff" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="💰" Foreground="#ffd700" FontSize="14"/>
                    <TextBlock x:Name="GoldText" Text="0G" Foreground="#ffd700" FontSize="14" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="⚖" Foreground="#a0c4ff" FontSize="14"/>
                    <TextBlock x:Name="WeightText" Text="0/100kg" Foreground="#a0c4ff" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text=" | " Foreground="Gray" FontSize="14"/>
                    <TextBlock Text="季節:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="SeasonText" Text="春" Foreground="#90EE90" FontSize="14" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="天候:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="WeatherText" Text="晴" Foreground="#87CEEB" FontSize="14" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="渇き:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="ThirstText" Text="潤沢" Foreground="#00BFFF" FontSize="14" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="善悪:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="KarmaText" Text="中立" Foreground="#C0C0C0" FontSize="14" FontWeight="Bold" Margin="0,0,8,0"/>
                    <TextBlock Text="仲間:" Foreground="White" FontSize="14"/>
                    <TextBlock x:Name="CompanionCountText" Text="0" Foreground="#FFD700" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ゲームマップ表示エリア -->
        <Border Grid.Row="1" Background="#0f0f23" Margin="10">
            <Grid>
                <Canvas x:Name="GameCanvas" ClipToBounds="True"/>
                <!-- ミニマップ（右上オーバーレイ） -->
                <Border x:Name="MinimapBorder"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,5,5,0"
                        Background="#80000000"
                        BorderBrush="#404060"
                        BorderThickness="1"
                        CornerRadius="3"
                        Visibility="Visible">
                    <Canvas x:Name="MinimapCanvas" 
                            Width="160" Height="100"
                            ClipToBounds="True"/>
                </Border>
            </Grid>
        </Border>

        <!-- メッセージログ -->
        <Border Grid.Row="2" Background="#16213e" Margin="10,0,10,5" Padding="10,5" MaxHeight="80">
            <ScrollViewer x:Name="MessageScroller" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="MessageLog" 
                           Foreground="#a0a0a0" 
                           FontFamily="Consolas" 
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- 操作説明 -->
        <Border Grid.Row="3" Background="#0f3460" Padding="10,5">
            <TextBlock x:Name="KeyHelpText"
                       Text="[WASD/矢印]移動 [I]持物 [C]状態 [L]ログ [G]拾う [&gt;]降 [&lt;]昇 [Tab]探索 [M]地図 [J]世界 [B]街 [K]依頼 [V]魔法 [E]技能 [O]信仰 [H]鍛冶 [P]祈り [Y]図鑑 [U]仲間 [Z]死亡録 [F5]保存 [F9]読込 [Q]終了"
                       Foreground="#e0e0e0" 
                       FontSize="12" 
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
