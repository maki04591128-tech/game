<Application x:Class="RougelikeGame.Gui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RougelikeGame.Gui"
             ShutdownMode="OnExplicitShutdown"
             Startup="Application_Startup">
    <Application.Resources>
        <!-- β.14: フォント見直し — ゲーム共通フォントスタイル -->
        <!-- ゲーム世界観（ダークファンタジー）に合わせ、游ゴシックで統一。読みやすさを優先。 -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="FontFamily" Value="Yu Gothic UI"/>
        </Style>
        <!-- β.16: ウィンドウ表示アニメーション — 全ウィンドウにフェードインを適用 -->
        <Style TargetType="Window">
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Window.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="Opacity"
                                From="0" To="1"
                                Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
