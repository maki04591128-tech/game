<Window x:Class="RougelikeGame.Gui.EncyclopediaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="図鑑" 
        Height="550" Width="650"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="【図鑑】" 
                       Foreground="#e94560" 
                       FontSize="18" 
                       FontWeight="Bold"/>
            <TextBlock x:Name="SummaryText"
                       Foreground="#4ecca3" 
                       FontSize="14" 
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
        </StackPanel>

        <!-- カテゴリタブ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="TabMonster" Content="モンスター" Width="100" Margin="0,0,5,0"
                    Click="TabMonster_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button x:Name="TabItem" Content="アイテム" Width="100" Margin="0,0,5,0"
                    Click="TabItem_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#0f3460" Padding="5,3"/>
            <Button x:Name="TabNpc" Content="NPC" Width="100" Margin="0,0,5,0"
                    Click="TabNpc_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#0f3460" Padding="5,3"/>
            <Button x:Name="TabRegion" Content="地域" Width="100" Margin="0,0,5,0"
                    Click="TabRegion_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#0f3460" Padding="5,3"/>
        </StackPanel>

        <!-- エントリ一覧と詳細 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0"
                     x:Name="EntryList"
                     Background="#16213e"
                     Foreground="White"
                     BorderBrush="#0f3460"
                     FontSize="13"
                     SelectionChanged="EntryList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="2">
                            <TextBlock Text="{Binding DiscoveryIcon}" Width="20"/>
                            <TextBlock Text="{Binding DisplayName}" Foreground="{Binding NameColor}"/>
                            <TextBlock Text="{Binding LevelText}" Foreground="#808080" Margin="8,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- エントリ詳細 -->
            <Border Grid.Column="1" Background="#0f3460" CornerRadius="4" Padding="10" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock x:Name="EntryNameText" Foreground="#ffd93d" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="EntryCategoryText" Foreground="#808080" FontSize="12" Margin="0,3,0,0"/>
                    <StackPanel x:Name="DiscoveryBar" Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="発見度: " Foreground="#a0a0a0" FontSize="12"/>
                        <TextBlock x:Name="DiscoveryLevelText" Foreground="#4ecca3" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                    <Border Background="#16213e" CornerRadius="3" Padding="8" Margin="0,8,0,0">
                        <TextBlock x:Name="EntryDescText" Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 下部情報・閉じるボタン -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <TextBlock x:Name="CategoryRateText" Foreground="#a0a0a0" FontSize="12" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
