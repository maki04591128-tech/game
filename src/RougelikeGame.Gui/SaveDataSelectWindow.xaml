<Window x:Class="RougelikeGame.Gui.SaveDataSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="セーブデータ選択" Height="500" Width="560"
        Background="#1a1a2e" WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" Text="セーブデータを選択"
                   Foreground="#ffd700" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- セーブデータリスト -->
        <Border Grid.Row="1" Background="#16213e" CornerRadius="5" Padding="5">
            <ListBox x:Name="SaveSlotList" Background="Transparent" BorderThickness="0"
                     Foreground="White" FontSize="13" SelectionChanged="SaveSlotList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1a1a3e" CornerRadius="4" Padding="10,8" Margin="2,3"
                                BorderBrush="#303060" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- スロット番号 -->
                                <TextBlock Grid.Column="0" Grid.RowSpan="2"
                                           Text="{Binding SlotLabel}" Foreground="#e94560"
                                           FontSize="18" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,12,0"/>

                                <!-- プレイヤー名・レベル・種族・職業 -->
                                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding PlayerName}" Foreground="White"
                                               FontSize="15" FontWeight="Bold" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding LevelText}" Foreground="#80c0ff"
                                               FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding RaceClassName}" Foreground="#a0a0c0"
                                               FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- 階層・領地・難易度 -->
                                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding FloorText}" Foreground="#80ffa0"
                                               FontSize="11" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding TerritoryText}" Foreground="#a0a0a0"
                                               FontSize="11" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding DifficultyText}" Foreground="#ffd080"
                                               FontSize="11"/>
                                </StackPanel>

                                <!-- セーブ日時 -->
                                <TextBlock Grid.Column="2" Grid.RowSpan="2"
                                           Text="{Binding SavedAtText}" Foreground="#808080"
                                           FontSize="11" VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 詳細情報 -->
        <Border Grid.Row="2" Background="#0f3460" CornerRadius="5" Padding="10,5" Margin="0,8,0,0">
            <TextBlock x:Name="DetailText" Text="セーブデータを選択してください"
                       Foreground="#e0e0e0" FontSize="12" TextWrapping="Wrap" FontFamily="Consolas"/>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="ロード [Enter]" Width="120" Height="35"
                    Click="LoadButton_Click" Background="#e94560" Foreground="White"
                    FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="削除 [Del]" Width="100" Height="35"
                    Click="DeleteButton_Click" Background="#604040" Foreground="#ff8080"
                    FontSize="13" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="戻る [Esc]" Width="100" Height="35"
                    Click="CancelButton_Click" Background="#333355" Foreground="White"
                    FontSize="13"/>
        </StackPanel>
    </Grid>
</Window>
