<Window x:Class="RougelikeGame.Gui.WorldMapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="世界マップ" 
        Height="600" Width="700"
        Background="#1a1a2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        KeyDown="Window_KeyDown">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0" 
                   Text="【世界マップ】" 
                   Foreground="#e94560" 
                   FontSize="18" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- 現在地情報 -->
        <Border Grid.Row="1" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="■ 現在地" Foreground="#4ecca3" FontSize="14" FontWeight="Bold" Margin="0,0,10,0"/>
                    <TextBlock x:Name="SurfaceDungeonStatus" Foreground="#ff6b6b" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock x:Name="CurrentTerritoryName" Foreground="#ffd93d" FontSize="16" FontWeight="Bold" Margin="0,3,0,0"/>
                <TextBlock x:Name="CurrentTerritoryDesc" Foreground="#a0a0a0" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock x:Name="CurrentLocationStatus" Foreground="#c0a0ff" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 3列レイアウト -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 隣接領地リスト -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="隣接領地" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                <ListBox Grid.Row="1"
                         x:Name="TerritoryList"
                         Background="#16213e"
                         Foreground="White"
                         BorderBrush="#0f3460"
                         FontSize="13"
                         SelectionChanged="TerritoryList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Foreground="#ffd93d" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding VisitedMark}" Foreground="#4ecca3" Margin="5,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding LevelRange}" Foreground="#808080" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- ロケーション/ダンジョン -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="ロケーション" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,3"/>
                <ListBox Grid.Row="1"
                         x:Name="LocationList"
                         Background="#16213e"
                         Foreground="White"
                         BorderBrush="#0f3460"
                         FontSize="12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" Foreground="#a0c4ff"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Grid.Row="2" Text="ダンジョン" Foreground="#e94560" FontSize="13" FontWeight="Bold" Margin="0,5,0,3"/>
                <ListBox Grid.Row="3"
                         x:Name="DungeonList"
                         Background="#16213e"
                         Foreground="White"
                         BorderBrush="#0f3460"
                         FontSize="12">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" Foreground="#ff6b6b"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- 施設一覧 -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="利用可能な施設" Foreground="#4ecca3" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                <ListBox Grid.Row="1"
                         x:Name="FacilityList"
                         Background="#16213e"
                         Foreground="White"
                         BorderBrush="#0f3460"
                         FontSize="13">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" Foreground="#a0c4ff"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- 選択領地情報 -->
        <Border Grid.Row="3" Background="#16213e" BorderBrush="#0f3460" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock x:Name="SelectedTerritoryInfo" Foreground="#a0a0a0" FontSize="12" TextWrapping="Wrap" Text="領地を選択してください"/>
            </StackPanel>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="TravelButton" Content="移動 [Enter]" Width="110" Margin="5"
                    Click="TravelButton_Click" IsEnabled="False"
                    Background="#0f3460" Foreground="White" BorderBrush="#4ecca3" Padding="5,3"/>
            <Button x:Name="EnterTownButton" Content="街に入る [T]" Width="110" Margin="5"
                    Click="EnterTownButton_Click" IsEnabled="False"
                    Background="#0f3460" Foreground="White" BorderBrush="#ffd93d" Padding="5,3"/>
            <Button Content="閉じる [Esc]" Width="100" Margin="5"
                    Click="CloseButton_Click"
                    Background="#0f3460" Foreground="White" BorderBrush="#e94560" Padding="5,3"/>
        </StackPanel>
    </Grid>
</Window>
